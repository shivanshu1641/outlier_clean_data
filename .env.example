# === Inference ===
# Any OpenAI-compatible endpoint (validator-injected values are preferred when present)
API_BASE_URL=https://router.huggingface.co/v1
API_KEY=
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
ENV_URL=http://localhost:8000
LOCAL_IMAGE_NAME=
LOG_LEVEL=INFO
LOG_DIR=outputs/logs
# Min seconds between LLM calls (Groq free tier: use 2.5; local/paid: use 0)
MIN_CALL_INTERVAL=2.5

# === Server ===
TASKS_DIR=tasks
DATA_DIR=data
SANDBOX_BASE=outputs/sandbox
UVICORN_WS_PING_INTERVAL=60
UVICORN_WS_PING_TIMEOUT=120
